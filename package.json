{
  "name": "ts2zig",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "bun run build.ts",
    "build:linux": "bun build --compile --target=bun-linux-x64 src/cli/index.ts --outfile dist/tszig-linux",
    "build:mac": "bun build --compile --target=bun-darwin-arm64 src/cli/index.ts --outfile dist/tszig-mac",
    "build:win": "bun build --compile --target=bun-windows-x64 src/cli/index.ts --outfile dist/tszig.exe"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "^1.3.14"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "citty": "^0.2.2"
  }
}
